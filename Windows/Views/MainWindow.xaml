<Window x:Class="Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TransFile"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#E5E7EB">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MenuTabStyle"
               TargetType="RadioButton">
            <Setter Property="Height"
                    Value="60"/>
            <Setter Property="Foreground"
                    Value="#1F2937"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder"
                                Background="#D1D5DB"
                                BorderBrush="#9CA3AF"
                                BorderThickness="0,0,0,1"
                                Margin="0,0,0,2">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5"
                                                  ShadowDepth="2"
                                                  Opacity="0.15"
                                                  Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="20,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#9CA3AF"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Margin="0,40,0,0">
            <RadioButton x:Name="RbShare"
                         Content="Share files with your phone"
                         Style="{StaticResource MenuTabStyle}"
                         IsChecked="True"/>
            <RadioButton x:Name="RbAccess"
                         Content="Access files from your phone"
                         Style="{StaticResource MenuTabStyle}"/>
            <RadioButton x:Name="RbSettings"
                         Content="Settings"
                         Style="{StaticResource MenuTabStyle}"/>
        </StackPanel>

        <Grid Grid.Column="1"
              Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontSize="14"
                       Foreground="#6B7280"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30">
                To connect your phone to the computer, generate the QR code on the computer and scan it with the app on your phone.
            </TextBlock>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsChecked, ElementName=RbShare, Converter={StaticResource BoolToVis}}">
                <ListBox x:Name="LstFiles"
                         Margin="0,0,0,80"
                         BorderBrush="#D1D5DB"
                         BorderThickness="1"
                         Background="#F9FAFB"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding FileName}"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Margin="0,0,15,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1"
                                        Content="X"
                                        Click="RemoveFile_Click"
                                        Tag="{Binding}"
                                        Foreground="White"
                                        Background="#EF4444"
                                        FontWeight="Bold"
                                        Width="24"
                                        Height="24"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button x:Name="BtnShare"
                        Content="Share"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Width="120"
                        Height="45"
                        Background="#3B82F6"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Opacity="0.5"
                        IsEnabled="False"
                        Cursor="Hand"/>

                <Button Click="AddFiles_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="60"
                        Height="60"
                        Background="#10B981"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,0,10"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="30">
                                <TextBlock Text="+"
                                           FontSize="38"
                                           FontWeight="Light"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,-5,0,0"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsChecked, ElementName=RbAccess, Converter={StaticResource BoolToVis}}">
                <ListBox Margin="0,0,0,80"
                         BorderBrush="#D1D5DB"
                         BorderThickness="1"
                         Background="#F9FAFB"/>
                <Button Content="Download"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Width="120"
                        Height="45"
                        Background="#3B82F6"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Opacity="0.5"
                        IsEnabled="False"
                        Cursor="Hand"/>
                <Button Content="Phone"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="120"
                        Height="45"
                        Background="#8B5CF6"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Margin="0,0,0,15"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsChecked, ElementName=RbSettings, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Select download Path:"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <Button x:Name="BtnDownloadPath"
                            Click="SelectPath_Click"
                            Content="C:\Users\Downloads\TransFile"
                            HorizontalContentAlignment="Left"
                            Padding="15,0"
                            Height="50"
                            Background="#F9FAFB"
                            BorderBrush="#9CA3AF"
                            BorderThickness="1"
                            FontSize="14"
                            Cursor="Hand"/>

                    <Button Content="Generate qr code"
                            Click="ShowConnectionQr_Click"
                            Margin="0,30,0,0"
                            Width="220"
                            Height="45"
                            HorizontalAlignment="Left"
                            Background="#10B981"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Download the mobile App"
                            Click="ShowDownloadAppQr_Click"
                            Margin="0,15,0,0"
                            Width="220"
                            Height="45"
                            HorizontalAlignment="Left"
                            Background="#10B981"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="QrOverlay"
              Grid.ColumnSpan="2"
              Background="#B3000000"
              Panel.ZIndex="100"
              Visibility="Collapsed">
            <Border Background="White"
                    Width="400"
                    Height="450"
                    CornerRadius="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Button Content="X"
                            Click="CloseQr_Click"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="15"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            Foreground="#8B0000"
                            BorderBrush="#8B0000"
                            BorderThickness="2"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"/>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="220"
                                Height="220"
                                Background="#F3F4F6"
                                BorderBrush="#D1D5DB"
                                BorderThickness="2"
                                Margin="0,0,0,30">
                            <Image x:Name="QrImage"
                                   Margin="10"/>
                        </Border>

                        <TextBlock x:Name="QrOverlayText"
                                   Text="scan with the app on your phone to connect"
                                   FontSize="18"
                                   FontWeight="Medium"
                                   Foreground="#374151"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Width="280"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>