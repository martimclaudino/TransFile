<Window x:Class="Windows.Views.MobileExplorerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mobile File Explorer"
        Height="450"
        Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
                Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="🡄 Back"
                    Click="BtnBack_Click"
                    Width="60"
                    Height="30"
                    Background="#E5E7EB"
                    BorderThickness="1"
                    BorderBrush="#D1D5DB"
                    Cursor="Hand"/>
            <TextBox x:Name="TxtCurrentPath"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    IsReadOnly="True"
                    VerticalContentAlignment="Center"
                    Background="White"/>
        </Grid>

        <ListBox x:Name="LstExplorer"
                Grid.Row="1"
                MouseDoubleClick="LstExplorer_MouseDoubleClick"
                BorderBrush="#D1D5DB"
                BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal"
                            Margin="5">
                        <TextBlock Text="{Binding Icon}"
                                Width="25"
                                Foreground="#D97706"
                                FontWeight="Bold"/>
                        <TextBlock Text="{Binding Name}"
                                VerticalAlignment="Center"
                                FontSize="14"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,15,0,0">
            <Button Content="Cancel"
                    Click="BtnCancel_Click"
                    Width="80"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#E5E7EB"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Select to Download"
                    Click="BtnSelect_Click"
                    Width="140"
                    Height="35"
                    Background="#3B82F6"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>